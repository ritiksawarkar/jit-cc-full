# Root-level .gitignore for JIT CC Full

# OS and Editor files
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.vscode/
!.vscode/extensions.json
.idea/

# Node modules at root (if any)
node_modules/

# Environment files
.env
.env.*
!.env.example
!*/.env.example

# Logs
logs/
*.log

# Misc
.cache/
.venv/
.venv-packages/
__pycache__/
