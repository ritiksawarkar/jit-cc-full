# ------------------------------
# Core Server
# ------------------------------
PORT=9009
AUTH_JWT_SECRET=change-me-to-a-long-random-string
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/compilerDB?retryWrites=true&w=majority

# ------------------------------
# Judge0 + AI
# ------------------------------
# Must be the full RapidAPI Judge0 host/subdomain, e.g. judge029.p.rapidapi.com
JUDGE0_HOST=judge029.p.rapidapi.com
JUDGE0_API_KEY=your_rapidapi_key_here

GEMINI_API_KEY=your_gemini_api_key_here
# Optional model override used by AI explanation route
GEMINI_MODEL=gemini-2.0-flash

# ------------------------------
# Frontend URL Resolution (password reset links)
# Priority in code: CLIENT_BASE_URL -> FRONTEND_URL -> APP_BASE_URL
# ------------------------------
CLIENT_BASE_URL=http://127.0.0.1:5173
FRONTEND_URL=
APP_BASE_URL=

# ------------------------------
# Forgot Password Email (SMTP)
# Keep SMTP_ENABLED=true to send email when SMTP is configured.
# If disabled or not configured, API falls back to returning reset URL.
# ------------------------------
SMTP_ENABLED=true
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@example.com
SMTP_PASS=your_email_app_password
SMTP_FROM=your_email@example.com

# When true, reset URL is included in API response even if email is sent.
# Usually keep false in production.
EXPOSE_RESET_LINK_IN_RESPONSE=false

# ------------------------------
# Event / Selection Controls
# ------------------------------
# Grace period (minutes) to allow initial problem lock after event starts
EVENT_SELECTION_UNLOCK_GRACE_MINUTES=20

# ------------------------------
# Advanced Execution Toggles (use with caution)
# ------------------------------
ALLOW_EXEC_ALL=false
ALLOW_DEP_INSTALL=false

# ------------------------------
# Seed Script Defaults (server/scripts/seedAdmin.js)
# ------------------------------
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=Admin@123
ADMIN_NAME=Platform Admin
